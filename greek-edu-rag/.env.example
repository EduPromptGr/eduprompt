# ─────────────────────────────────────────────────────────────
# EduPrompt Backend — Environment Variables
# Αντίγραψε σε .env και συμπλήρωσε τα πραγματικά values.
# ΜΗΝ κάνεις commit το .env — είναι στο .gitignore.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co

# Settings → API → Project API keys → service_role (server-only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase

# ── Anthropic (Claude AI) ─────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Ποιο μοντέλο να χρησιμοποιείς:
# claude-3-5-haiku-20241022   → γρήγορο, φθηνό (~$0.01/σενάριο)
# claude-3-5-sonnet-20241022  → καλύτερο, ακριβότερο (~$0.05/σενάριο)
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ── Pinecone (RAG) ────────────────────────────────────────────
# app.pinecone.io → API Keys
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX=eduprompt-rag

# ── Stripe ────────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Resend) ────────────────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=re_...
EMAIL_FROM=hello@eduprompt.gr

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://eduprompt.gr

# ── Internal ──────────────────────────────────────────────────
# Secret για Next.js → FastAPI internal calls (rate-limit invalidation)
INTERNAL_API_SECRET=dev-internal-secret-change-in-prod

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
